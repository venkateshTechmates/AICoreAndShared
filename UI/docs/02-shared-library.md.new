## 15. Cost Management (`ai_shared.cost`)

Track, analyse, and enforce budgets for all LLM usage.

```python
from ai_shared.cost import CostTracker, CostOptimizer, QuotaManager, estimate_cost
from datetime import datetime, timedelta

# ── Cost estimation (standalone) ──
cost = estimate_cost(
    model="gpt-4o",
    input_tokens=5000,
    output_tokens=1000,
)   # → $0.040

# ── Cost Tracker ──
tracker = CostTracker()

# Record a usage event
record = tracker.record(
    provider="openai",
    model="gpt-4o",
    input_tokens=2000,
    output_tokens=500,
    user_id="alice",
    project="enterprise-kb",
)

# Aggregate queries
total = tracker.total_cost(since=datetime.utcnow() - timedelta(days=30))
by_model = tracker.cost_by_model()
# {"gpt-4o": 145.20, "gpt-4o-mini": 8.35}

by_user = tracker.cost_by_user()
# {"alice": 78.10, "bob": 45.20, ...}

# ── Cost Optimizer — suggest cheaper alternatives ──
optimizer = CostOptimizer(tracker=tracker)
suggestions = optimizer.suggest_model_swap(
    current_model="gpt-4o",
    quality_threshold=0.85,
)
# [{"swap_to": "gpt-4o-mini", "estimated_savings_pct": 97, "quality_impact": -0.03}]

# ── Quota Manager ──
quotas = QuotaManager(tracker=tracker)
quotas.set_quota(user_id="alice",   monthly_limit_usd=100.0)
quotas.set_quota(project="test-env", daily_limit_usd=10.0)

is_allowed = await quotas.check(user_id="alice", estimated_cost=0.05)
if not is_allowed:
    raise QuotaExceededError("Monthly budget exhausted")
```

