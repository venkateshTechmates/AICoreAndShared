## 14. Data Governance (`ai_shared.governance`)

Enterprise data lineage, classification, policy enforcement, and GDPR tooling.

```python
from ai_shared.governance import (
    DataClassifier,
    DataLineageTracker,
    PolicyEngine,
    AuditLogger,
    RetentionManager,
    GDPRManager,
    ClassificationLevel,
)

# ── Data Classification ──
classifier = DataClassifier(
    default_level=ClassificationLevel.INTERNAL,
    rules={
        "ssn": ClassificationLevel.RESTRICTED,
        "password": ClassificationLevel.RESTRICTED,
        "internal_only": ClassificationLevel.CONFIDENTIAL,
    },
)

result = classifier.classify("User SSN: 123-45-6789", metadata={"source": "crm"})
# ClassificationResult(level=RESTRICTED, labels=["ssn"], confidence=0.85)

# ── Data Lineage Tracking ──
lineage = DataLineageTracker()
source_id = lineage.add_source("CRM Export", metadata={"table": "customers"})
chunk_id  = lineage.add_transform("Chunking", source_id, transform_desc="semantic split")
embed_id  = lineage.add_transform("Embedding", chunk_id, transform_desc="text-embedding-3-large")
lineage.add_output("Qdrant upsert", embed_id)

path = lineage.get_lineage(embed_id)    # full provenance chain

# ── Policy Engine ──
policy = PolicyEngine()
policy.add_rule("no_pii_in_logs",   condition=lambda d: d.has_pii, action="redact")
policy.add_rule("restrict_export",  condition=lambda d: d.level == "RESTRICTED", action="block")
decision = await policy.evaluate(data_object)

# ── Audit Logger ──
audit_logger = AuditLogger(backend="postgres", connection_string="${AUDIT_DB_URL}")
await audit_logger.log_access(user_id="alice", resource="doc-123", action="read")
await audit_logger.log_mutation(user_id="bob",  resource="doc-456", action="delete")

# ── GDPR Manager ──
gdpr = GDPRManager(lineage_tracker=lineage, audit_logger=audit_logger)
await gdpr.handle_erasure_request(user_id="user-789")   # right to be forgotten
report = await gdpr.generate_dsar(user_id="user-789")   # data subject access request
```

