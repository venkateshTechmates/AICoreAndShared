## 18. Model Registry & A/B Testing (`ai_shared.models`)

Version control, promotion workflows, and A/B testing for production models.

```python
from ai_shared.models import ModelRegistry, ABTestingFramework, RollbackManager

# ── Model Registry ──
registry = ModelRegistry()

# Register a new model version
v1 = registry.register(
    name="rag-pipeline",
    provider="openai",
    config={"model": "gpt-4o", "temperature": 0.1},
    metrics={"faithfulness": 0.89, "latency_p50_ms": 280},
    tags=["production", "stable"],
)

v2 = registry.register(
    name="rag-pipeline",
    provider="openai",
    config={"model": "gpt-4o", "temperature": 0.05},
    metrics={"faithfulness": 0.93, "latency_p50_ms": 310},
    tags=["candidate"],
)

# Get current active version
active = registry.get_active("rag-pipeline")

# Promote v2 to production
registry.promote("rag-pipeline", v2.version_id)

# ── A/B Testing ──
ab = ABTestingFramework(registry=registry)
ab_exp = ab.create_experiment(
    name="Temperature 0.1 vs 0.05",
    model_name="rag-pipeline",
    control_version=v1.version_id,
    treatment_version=v2.version_id,
    traffic_split=0.2,                  # 20% treatment
)

# Route a request
selected_version = ab.assign(ab_exp.experiment_id, user_id="alice")
config = registry.get_version(selected_version).config

# ── Rollback Manager ──
rollback = RollbackManager(registry=registry)

# Trigger rollback on quality degradation
await rollback.rollback(
    name="rag-pipeline",
    reason="faithfulness dropped below 0.85",
    restore_to=v1.version_id,
)

# Automatic rollback on metrics threshold
rollback.configure_auto_rollback(
    name="rag-pipeline",
    metric="faithfulness",
    threshold=0.85,
    direction="less_than",
)
```
