## 9. Authentication & Authorization (`ai_shared.auth`)

```python
from ai_shared.auth import JWTValidator, APIKeyManager, RBAC, AuthManager, Permission

# ── JWT Validation ──
validator = JWTValidator(
    secret="your-hs256-secret",         # or jwks_url for RS256
    audience="ai-core-api",
    issuer="https://auth.company.com",
)

auth_result = validator.validate(token)
if auth_result.authenticated:
    user = auth_result.user

# ── API Key Management ──
key_manager = APIKeyManager()
key = key_manager.create_key(user_id="svc-account-1", scopes=["rag.query"])
is_valid = key_manager.validate_key(api_key_string)

# ── Role-Based Access Control ──
rbac = RBAC()
rbac.add_role("admin",          [Permission.ADMIN])
rbac.add_role("data_scientist", [Permission.READ, Permission.WRITE, Permission.EXECUTE])
rbac.add_role("viewer",         [Permission.READ])

rbac.assign_role(user_id="alice", role="data_scientist")

if rbac.has_permission(user_id="alice", permission=Permission.WRITE):
    await rag.ingest(documents)

# ── Unified Auth Manager ──
auth = AuthManager(
    jwt_validator=validator,
    key_manager=key_manager,
    rbac=rbac,
)

result = auth.authenticate(token_or_key)
```

