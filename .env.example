# ============================================================
# AI Enterprise Toolkit — Environment Variable Reference
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Library ─────────────────────────────────────────────────
AI_CORE_ENV=development          # development | staging | production
AI_CORE_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
AI_CORE_LOG_JSON=false           # true = JSON-lines output

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...            # optional

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Azure OpenAI ────────────────────────────────────────────
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── AWS Bedrock ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# ── Google Vertex AI ────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_PROJECT=my-gcp-project
VERTEX_LOCATION=us-central1

# ── Groq ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Together AI ─────────────────────────────────────────────
TOGETHER_API_KEY=...

# ── Ollama (local) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Cohere ──────────────────────────────────────────────────
COHERE_API_KEY=...

# ── Jina ────────────────────────────────────────────────────
JINA_API_KEY=...

# ── Vector Stores ───────────────────────────────────────────
# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                  # leave empty for local

# Pinecone
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws

# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=                # leave empty for local

# Milvus / Zilliz
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=                    # leave empty for local

# Chroma (default: in-memory)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# PgVector
PGVECTOR_DSN=postgresql://user:password@localhost:5432/ai_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<resource>.search.windows.net
AZURE_SEARCH_API_KEY=...

# OpenSearch
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_VERIFY_CERTS=false

# ── Observability ───────────────────────────────────────────
# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ai-enterprise-toolkit

# Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-enterprise-toolkit

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── HashiCorp Vault (for LibConfig.from_vault) ──────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=...

# ── Cost / Quota ────────────────────────────────────────────
COST_LIMIT_USD=10.0              # hard stop for RAG pipeline
DEFAULT_QUOTA_DAILY_USD=5.0
DEFAULT_QUOTA_DAILY_REQUESTS=1000
